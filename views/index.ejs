<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nispadaya - Just get it done!</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'dark-bg': '#0f172a',
                        'dark-card': '#1e293b',
                        'dark-border': '#334155',
                        'accent': '#64748b',
                    }
                }
            }
        }
    </script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #0a0e27 0%, #1a1f2e 50%, #0d1117 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #cbd5e1;
            min-height: 100vh;
        }

        /* Animations */
        @keyframes slideInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes float {
            0%, 100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-10px);
            }
        }

        @keyframes glow {
            0%, 100% {
                text-shadow: 0 4px 12px rgba(0, 0, 0, 0.4);
            }
            50% {
                text-shadow: 0 4px 20px rgba(100, 116, 139, 0.3);
            }
        }

        /* Navigation Bar Styling */
        nav {
            background: linear-gradient(90deg, rgba(10, 14, 39, 0.99) 0%, rgba(20, 24, 50, 0.98) 100%);
            backdrop-filter: blur(10px);
            border-bottom: 2px solid rgba(255, 255, 255, 0.08);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            animation: slideInDown 0.6s ease-out;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
        }

        .nav-brand {
            font-size: 1.75rem;
            font-weight: 700;
            color: #e2e8f0;
            letter-spacing: 0.05em;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
            animation: fadeInUp 0.8s ease-out 0.1s both;
        }

        .nav-links {
            display: flex;
            gap: 1.5rem;
            align-items: center;
        }

        .nav-link {
            color: #cbd5e1;
            text-decoration: none;
            padding: 0.5rem 1rem;
            border-radius: 0.375rem;
            transition: all 0.3s ease;
            animation: fadeInUp 0.8s ease-out 0.2s both;
            font-size: 0.95rem;
            position: relative;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: #a1aec6;
            transition: width 0.3s ease;
        }

        .nav-link:hover {
            color: #f1f5f9;
        }

        .nav-link:hover::after {
            width: 100%;
        }

        /* Hero Section */
        .hero {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: calc(100vh - 80px);
            text-align: center;
            padding: 2rem;
        }

        .hero h1 {
            font-size: 4rem;
            font-weight: 700;
            color: #e2e8f0;
            margin-bottom: 2rem;
            line-height: 1.2;
            letter-spacing: -0.02em;
            animation: fadeInUp 1s ease-out 0.3s both, float 3s ease-in-out 1.3s infinite, glow 3s ease-in-out 1.3s infinite;
        }

        .hero-subtitle {
            font-size: 1.3rem;
            color: #a1aec6;
            margin-bottom: 3rem;
            max-width: 600px;
            line-height: 1.6;
            font-weight: 300;
            animation: fadeInUp 1s ease-out 0.5s both;
        }

        .hero-buttons {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            flex-wrap: wrap;
            animation: fadeInUp 1s ease-out 0.7s both;
            flex-wrap: wrap;
        }

        .btn {
            padding: 0.875rem 2rem;
            border-radius: 0.5rem;
            text-decoration: none;
            font-weight: 600;
            animation: fadeInUp 1s ease-out 0.8s both;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            font-size: 1rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, #64748b 0%, #475569 100%);
            color: #f1f5f9;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #78899e 0%, #54637d 100%);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(100, 116, 139, 0.3);
        }

        .btn-secondary {
            background: transparent;
            color: #cbd5e1;
            border: 2px solid #64748b;
        }

        .btn-secondary:hover {
            background: rgba(100, 116, 139, 0.1);
            border-color: #94a3b8;
            color: #e2e8f0;
            transform: translateY(-2px);
        }

        /* Decorative elements */
        .decoration {
            position: fixed;
            pointer-events: none;
        }

        .decoration-top-left {
            top: -100px;
            left: -100px;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(100, 116, 139, 0.1) 0%, transparent 70%);
            border-radius: 50%;
        }

        .decoration-bottom-right {
            bottom: -150px;
            right: -150px;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(100, 116, 139, 0.08) 0%, transparent 70%);
            border-radius: 50%;
        }

        @media (max-width: 640px) {
            .hero h1 {
                font-size: 2.5rem;
            }

            .hero-subtitle {
                font-size: 1rem;
            }

            nav {
                flex-direction: column;
                gap: 1rem;
            }

            .nav-links {
                width: 100%;
                justify-content: center;
                gap: 1rem;
            }
        }
    </style>
</head>
<body>
    <!-- Decorative elements -->
    <div class="decoration decoration-top-left"></div>
    <div class="decoration decoration-bottom-right"></div>

    <!-- Navigation Bar -->
    <nav>
        <div class="nav-brand">Nispadaya</div>
        <div class="nav-links">
            <a href="/login" class="nav-link">Login</a>
            <a href="/create-account" class="nav-link">Create Account</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <h1>Nispadaya! Just get it done!</h1>
        <p class="hero-subtitle">Discover amazing stories and content at your own pace. Your reading companion is always here.</p>
        <div class="hero-buttons">
            <a href="/create-account" class="btn btn-primary">Get Started</a>
            <a href="#" class="btn btn-secondary">Learn More</a>
        </div>
    </section>
</body>
</html>
