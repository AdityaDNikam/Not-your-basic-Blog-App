<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user.username %> - Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #0f172a 0%, #1a1f3a 50%, #0f172a 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #cbd5e1;
            min-height: 100vh;
        }

        /* Navigation Bar */
        nav {
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(51, 65, 85, 0.3);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-username {
            font-size: 1.5rem;
            font-weight: 700;
            color: #e2e8f0;
            letter-spacing: 0.05em;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
        }

        .nav-buttons {
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        .nav-btn {
            padding: 0.5rem 1.25rem;
            border: 1px solid rgba(100, 116, 139, 0.3);
            border-radius: 0.375rem;
            background: rgba(100, 116, 139, 0.1);
            color: #cbd5e1;
            text-decoration: none;
            cursor: pointer;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .nav-btn:hover {
            background: rgba(100, 116, 139, 0.2);
            border-color: rgba(100, 116, 139, 0.5);
            transform: translateY(-1px);
        }

        .nav-btn:active {
            transform: translateY(0);
        }

        .nav-btn.logout {
            background: rgba(239, 68, 68, 0.1);
            border-color: rgba(239, 68, 68, 0.3);
            color: #fca5a5;
        }

        .nav-btn.logout:hover {
            background: rgba(239, 68, 68, 0.2);
            border-color: rgba(239, 68, 68, 0.5);
        }

        /* Hero Section */
        .hero-section {
            padding: 3rem 2rem;
            background: rgba(30, 41, 59, 0.4);
            border-bottom: 1px solid rgba(51, 65, 85, 0.3);
        }

        .hero-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            gap: 3rem;
        }

        .hero-photo {
            flex-shrink: 0;
        }

        .hero-photo img {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            border: 3px solid rgba(100, 116, 139, 0.5);
            object-fit: cover;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            transition: all 0.3s ease;
        }

        .hero-photo img:hover {
            border-color: rgba(100, 116, 139, 0.8);
            box-shadow: 0 15px 40px rgba(100, 116, 139, 0.2);
        }

        .hero-info {
            flex: 1;
        }

        .hero-username {
            font-size: 2.5rem;
            font-weight: 700;
            color: #e2e8f0;
            display: inline;
            margin-right: 0.5rem;
        }

        .hero-divider {
            font-size: 2rem;
            color: #64748b;
            display: inline;
            margin: 0 0.75rem;
        }

        .hero-userid {
            font-size: 1.25rem;
            color: #94a3b8;
            display: inline;
            font-weight: 500;
        }

        .hero-meta {
            margin-top: 1rem;
            color: #a1aec6;
            font-size: 0.95rem;
        }

        /* Blog Section */
        .blogs-section {
            padding: 3rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-title {
            font-size: 1.75rem;
            font-weight: 700;
            margin-bottom: 2rem;
            color: #e2e8f0;
        }

        .blogs-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
            margin-bottom: 3rem;
        }

        .blog-card {
            background: rgba(30, 41, 59, 0.6);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(51, 65, 85, 0.3);
            border-radius: 0.75rem;
            padding: 1.5rem;
            transition: all 0.3s ease;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .blog-card:hover {
            background: rgba(30, 41, 59, 0.8);
            border-color: rgba(100, 116, 139, 0.5);
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
        }

        .blog-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: #e2e8f0;
            margin-bottom: 1rem;
            line-height: 1.4;
        }

        .blog-message {
            color: #cbd5e1;
            font-size: 0.95rem;
            line-height: 1.6;
            flex: 1;
        }

        .blog-footer {
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid rgba(51, 65, 85, 0.3);
            color: #64748b;
            font-size: 0.85rem;
        }

        .blog-footer a {
            color: #64748b;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .blog-footer a:hover {
            color: #cbd5e1;
        }

        /* Blog Action Buttons */
        .blog-actions {
            display: flex;
            gap: 0.75rem;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid rgba(51, 65, 85, 0.3);
        }

        .btn-action {
            flex: 1;
            padding: 0.5rem;
            border: 1px solid rgba(100, 116, 139, 0.3);
            border-radius: 0.375rem;
            background: rgba(100, 116, 139, 0.1);
            color: #cbd5e1;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-action:hover {
            background: rgba(100, 116, 139, 0.2);
            border-color: rgba(100, 116, 139, 0.5);
            transform: translateY(-2px);
        }

        .btn-edit {
            background: rgba(59, 130, 246, 0.1);
            border-color: rgba(59, 130, 246, 0.3);
            color: #93c5fd;
        }

        .btn-edit:hover {
            background: rgba(59, 130, 246, 0.2);
            border-color: rgba(59, 130, 246, 0.5);
        }

        .btn-delete {
            background: rgba(239, 68, 68, 0.1);
            border-color: rgba(239, 68, 68, 0.3);
            color: #fca5a5;
        }

        .btn-delete:hover {
            background: rgba(239, 68, 68, 0.2);
            border-color: rgba(239, 68, 68, 0.5);
        }

        /* Create Blog Button */
        .create-blog-btn {
            display: inline-block;
            padding: 0.75rem 1.5rem;
            background: rgba(34, 197, 94, 0.1);
            border: 1px solid rgba(34, 197, 94, 0.3);
            color: #86efac;
            border-radius: 0.375rem;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 600;
            transition: all 0.3s ease;
            margin-bottom: 2rem;
        }

        .create-blog-btn:hover {
            background: rgba(34, 197, 94, 0.2);
            border-color: rgba(34, 197, 94, 0.5);
            transform: translateY(-2px);
        }

        .create-blog-btn:active {
            transform: translateY(0);
        }

        /* Modal Styles */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: rgba(30, 41, 59, 0.95);
            border: 1px solid rgba(51, 65, 85, 0.3);
            border-radius: 0.75rem;
            padding: 2rem;
            max-width: 600px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-header {
            font-size: 1.5rem;
            font-weight: 700;
            color: #e2e8f0;
            margin-bottom: 1.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            margin-bottom: 0.5rem;
            color: #cbd5e1;
            font-weight: 500;
        }

        .form-input, .form-textarea {
            width: 100%;
            padding: 0.75rem;
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid rgba(51, 65, 85, 0.3);
            border-radius: 0.375rem;
            color: #e2e8f0;
            font-family: inherit;
            transition: all 0.3s ease;
        }

        .form-input:focus, .form-textarea:focus {
            outline: none;
            background: rgba(15, 23, 42, 0.7);
            border-color: rgba(100, 116, 139, 0.5);
            box-shadow: 0 0 0 3px rgba(100, 116, 139, 0.1);
        }

        .form-textarea {
            resize: vertical;
            min-height: 120px;
        }

        .modal-actions {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            justify-content: flex-end;
        }

        .btn-modal {
            padding: 0.75rem 1.5rem;
            border: 1px solid rgba(100, 116, 139, 0.3);
            border-radius: 0.375rem;
            cursor: pointer;
            font-size: 0.95rem;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-submit {
            background: rgba(34, 197, 94, 0.1);
            border-color: rgba(34, 197, 94, 0.3);
            color: #86efac;
        }

        .btn-submit:hover {
            background: rgba(34, 197, 94, 0.2);
            border-color: rgba(34, 197, 94, 0.5);
        }

        .btn-cancel {
            background: rgba(100, 116, 139, 0.1);
            border-color: rgba(100, 116, 139, 0.3);
            color: #cbd5e1;
        }

        .btn-cancel:hover {
            background: rgba(100, 116, 139, 0.2);
            border-color: rgba(100, 116, 139, 0.5);
        }

        @media (max-width: 1024px) {
            .blogs-grid {
                grid-template-columns: repeat(3, 1fr);
            }

            .hero-container {
                flex-direction: column;
                text-align: center;
                gap: 2rem;
            }

            .hero-photo img {
                width: 150px;
                height: 150px;
            }

            .hero-username {
                font-size: 2rem;
            }

            .hero-userid {
                font-size: 1rem;
            }
        }

        @media (max-width: 768px) {
            .blogs-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            nav {
                flex-direction: column;
                gap: 1rem;
            }

            .nav-buttons {
                width: 100%;
                justify-content: center;
            }

            .hero-section {
                padding: 2rem 1rem;
            }

            .hero-container {
                gap: 1.5rem;
            }

            .hero-photo img {
                width: 130px;
                height: 130px;
            }

            .hero-username {
                font-size: 1.5rem;
            }

            .hero-divider {
                font-size: 1.25rem;
            }

            .hero-userid {
                font-size: 0.95rem;
            }
        }

        @media (max-width: 480px) {
            .blogs-grid {
                grid-template-columns: 1fr;
            }

            .nav-username {
                font-size: 1.25rem;
            }

            .nav-btn {
                padding: 0.4rem 0.8rem;
                font-size: 0.85rem;
            }

            .hero-photo img {
                width: 100px;
                height: 100px;
            }

            .hero-username {
                font-size: 1.25rem;
            }

            .hero-divider {
                display: block;
                margin: 0.5rem 0;
            }

            .blogs-section {
                padding: 1.5rem 1rem;
            }

            .blog-title {
                font-size: 1rem;
            }

            .blog-message {
                font-size: 0.9rem;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation Bar -->
    <nav>
        <div class="nav-username"><%= user.username %></div>
        <div class="nav-buttons">
            <a href="/profile" class="nav-btn">Profile</a>
            <a href="/logout" class="nav-btn logout">Logout</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-container">
            <div class="hero-photo">
                <img src="https://api.dicebear.com/7.x/initials/svg?seed=<%= encodeURIComponent(user.name) %>&backgroundColor=64748b&textColor=ffffff&scale=85" alt="<%= user.username %>">
            </div>
            <div class="hero-info">
                <div>
                    <span class="hero-username"><%= user.name %></span>
                    <span class="hero-divider">/</span>
                    <span class="hero-userid"><%= user.userId %></span>
                </div>
                <div class="hero-meta">
                    @<%= user.username %> • Joined <%= new Date(user.createdAt).toLocaleDateString() %>
                </div>
            </div>
        </div>
    </section>

    <!-- Blogs Section -->
    <section class="blogs-section">
        <h2 class="section-title">Latest Articles</h2>
        <button class="create-blog-btn" onclick="openCreateModal()">+ Create Blog Post</button>
        <div class="blogs-grid">
            <% if (blogs && blogs.length > 0) { %>
                <% blogs.forEach((blog) => { %>
                    <div class="blog-card">
                        <h3 class="blog-title"><%= blog.Blog_header %></h3>
                        <p class="blog-message">
                            <%= blog.Blog_msg %>
                        </p>
                        <% if (blog.related_url) { %>
                            <div class="blog-footer">
                                <a href="<%= blog.related_url %>" target="_blank" rel="noopener noreferrer" style="color: #64748b; text-decoration: none; transition: color 0.3s ease;">
                                    View link →
                                </a>
                            </div>
                        <% } else { %>
                            <div class="blog-footer">
                                <%= new Date(blog.createdAt).toLocaleDateString() %>
                            </div>
                        <% } %>
                        <div class="blog-actions">
                            <button class="btn-action btn-edit" onclick="openEditModal(<%= JSON.stringify({id: blog._id.toString(), header: blog.Blog_header, msg: blog.Blog_msg, url: blog.related_url || ''}) %>)">
                                ✏️ Edit
                            </button>
                            <button class="btn-action btn-delete" onclick="deleteBlog('<%= blog._id %>')">
                                🗑️ Delete
                            </button>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="blog-card" style="grid-column: 1/-1; text-align: center; padding: 3rem;">
                    <p style="color: #a1aec6; font-size: 1rem;">
                        No blogs yet. Start by creating your first blog!
                    </p>
                </div>
            <% } %>
        </div>
    </section>

    <!-- Blog Modal -->
    <div id="blogModal" class="modal">
        <div class="modal-content">
            <div class="modal-header" id="modalTitle">Create Blog Post</div>
            <form id="blogForm">
                <div class="form-group">
                    <label class="form-label" for="blogHeader">Blog Title</label>
                    <input type="text" id="blogHeader" class="form-input" required placeholder="Enter blog title">
                </div>
                <div class="form-group">
                    <label class="form-label" for="blogMsg">Blog Content</label>
                    <textarea id="blogMsg" class="form-textarea" required placeholder="Enter blog content"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label" for="blogUrl">Related URL (Optional)</label>
                    <input type="url" id="blogUrl" class="form-input" placeholder="Enter related URL (optional)">
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-modal btn-cancel" onclick="closeModal()">Cancel</button>
                    <button type="submit" class="btn-modal btn-submit">Submit</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        let currentBlogId = null;

        // Open Create Modal
        function openCreateModal() {
            currentBlogId = null;
            document.getElementById('modalTitle').textContent = 'Create Blog Post';
            document.getElementById('blogForm').reset();
            document.getElementById('blogForm').onsubmit = createBlog;
            document.getElementById('blogModal').classList.add('active');
        }

        // Open Edit Modal
        function openEditModal(blogData) {
            currentBlogId = blogData.id;
            document.getElementById('modalTitle').textContent = 'Edit Blog Post';
            document.getElementById('blogHeader').value = blogData.header;
            document.getElementById('blogMsg').value = blogData.msg;
            document.getElementById('blogUrl').value = blogData.url;
            document.getElementById('blogForm').onsubmit = updateBlog;
            document.getElementById('blogModal').classList.add('active');
        }

        // Close Modal
        function closeModal() {
            document.getElementById('blogModal').classList.remove('active');
            currentBlogId = null;
        }

        // Create Blog
        async function createBlog(e) {
            e.preventDefault();
            
            const blogHeader = document.getElementById('blogHeader').value;
            const blogMsg = document.getElementById('blogMsg').value;
            const relatedUrl = document.getElementById('blogUrl').value;

            try {
                const response = await fetch('/api/blogs', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        Blog_header: blogHeader,
                        Blog_msg: blogMsg,
                        related_url: relatedUrl || null,
                    }),
                });

                const data = await response.json();

                if (response.ok) {
                    alert('Blog created successfully!');
                    closeModal();
                    // Reload the page to show the new blog
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (error) {
                alert('Error creating blog: ' + error.message);
            }
        }

        // Update Blog
        async function updateBlog(e) {
            e.preventDefault();
            
            if (!currentBlogId) return;

            const blogHeader = document.getElementById('blogHeader').value;
            const blogMsg = document.getElementById('blogMsg').value;
            const relatedUrl = document.getElementById('blogUrl').value;

            try {
                const response = await fetch(`/api/blogs/${currentBlogId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        Blog_header: blogHeader,
                        Blog_msg: blogMsg,
                        related_url: relatedUrl || null,
                    }),
                });

                const data = await response.json();

                if (response.ok) {
                    alert('Blog updated successfully!');
                    closeModal();
                    // Reload the page to show updated blog
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (error) {
                alert('Error updating blog: ' + error.message);
            }
        }

        // Delete Blog
        async function deleteBlog(blogId) {
            if (!confirm('Are you sure you want to delete this blog?')) {
                return;
            }

            try {
                const response = await fetch(`/api/blogs/${blogId}`, {
                    method: 'DELETE',
                });

                const data = await response.json();

                if (response.ok) {
                    alert('Blog deleted successfully!');
                    // Reload the page to refresh the blog list
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (error) {
                alert('Error deleting blog: ' + error.message);
            }
        }

        // Close modal when clicking outside
        document.getElementById('blogModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeModal();
            }
        });
    </script>
</body>
</html>
